# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=marvaron_user
DB_PASSWORD=marvaron_password
DB_NAME=marvaron_db
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# QR Code Encryption
QR_ENCRYPTION_KEY=your-32-byte-encryption-key-for-aes-256
QR_SIGNATURE_SECRET=your-signature-secret-for-qr-verification

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_QR_SCANS=qr-scans
KAFKA_TOPIC_ORDERS=orders
KAFKA_TOPIC_INVENTORY=inventory

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# AWS Configuration (if needed)
AWS_REGION=us-east-1
AWS_S3_BUCKET=marvaron-assets

# Push Notification (FCM)
FCM_SERVER_KEY=your-fcm-server-key
